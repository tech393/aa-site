ANTHROPIC_API_KEY=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Base URL for externally hosted audio assets (Cloudflare R2, Bunny, S3, etc.).
# MP3s live outside the repo because Git LFS pointers don't deploy as playable
# files on Vercel and the 108 MB Advanced LOA file exceeds GitHub's per-file
# limit. Leave empty in local dev (LFS-hydrated files in public/ are served).
# Example: NEXT_PUBLIC_AUDIO_CDN=https://pub-abc123.r2.dev
NEXT_PUBLIC_AUDIO_CDN=
