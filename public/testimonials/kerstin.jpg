@media only screen and (max-width: 768px) {
	.menu-holder {
		display: none;
	}
	
	nav#top-menu-nav, #top-menu, nav.fullwidth-menu-nav, .fullwidth-menu {
		float: right !important;
	}
	
	/*EASY SOCIAL SHARE*/
	.essb_links.essb_template_metro-retina li a {
		width: 100%;
		text-align: center;
		padding: 15px 95px 20px 70px;
	}
	
	body h1 {
		font-size: 50px ;
	}
	
	body h2 {
		font-size: 40px ;
	}
	
	body h3 {
		font-size: 33px ;
	}
	
	body h4 {
		font-size: 30px ;
	}
	
	body h5 {
		font-size: 18px ;
	}
	
	body h6 {
		font-size: 48px ;
	}
	
	body .custom-h6 h6 {
		font-size: 40px ;
	}
	
	body p {
		font-size: 1.3em ;
	}
	
	ul li {
		font-size: 1.2em ;
      	line-height: 1.7em ;
		font-family: merryweather;
		font-weight: 300;
	}
	
	/* BLOG */
	article h2 {
